<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.KutiraKushala" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_green_light</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar">false</item>

        <item name="colorSurface">@color/card_dark</item>
        <item name="colorOnSurface">@color/text_primary_dark</item>
        <item name="colorSurfaceVariant">@color/input_dark</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary_dark</item>
    </style>

    <style name="CircleImage" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">50%</item>
    </style>

    <style name="Rounded12" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">12dp</item>
    </style>

    <style name="TransparentDialog" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>
</resources>