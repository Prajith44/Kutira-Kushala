<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6F8">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/ll_status_actions"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <ImageButton
                android:id="@+id/btn_back_tracking"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/circle_white_bg"
                android:contentDescription="Back"
                android:src="@android:drawable/ic_menu_revert"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="#1A1A1A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Track Order"
                android:textColor="#1A1A1A"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/btn_back_tracking"
                app:layout_constraintStart_toEndOf="@+id/btn_back_tracking"
                app:layout_constraintTop_toTopOf="@+id/btn_back_tracking" />

            <!-- Order Summary Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cv_order_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:layout_constraintTop_toBottomOf="@+id/btn_back_tracking">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_track_buyer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GreenField Exports"
                        android:textColor="#1A1A1A"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_track_product"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="500 x Bamboo Baskets"
                        android:textColor="#4B5563"
                        android:textSize="14sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#EDEFF2" />

                    <TextView
                        android:id="@+id/tv_current_status_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/filter_chip_unselected"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:text="PROCESSING"
                        android:textColor="#1F5D57"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Timeline Section -->
            <LinearLayout
                android:id="@+id/ll_timeline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@+id/cv_order_summary">

                <include
                    android:id="@+id/step_requested"
                    layout="@layout/item_timeline_step" />

                <include
                    android:id="@+id/step_accepted"
                    layout="@layout/item_timeline_step" />

                <include
                    android:id="@+id/step_processing"
                    layout="@layout/item_timeline_step" />

                <include
                    android:id="@+id/step_ready"
                    layout="@layout/item_timeline_step" />

                <include
                    android:id="@+id/step_delivered"
                    layout="@layout/item_timeline_step" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/ll_status_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:elevation="16dp"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btn_next_status"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/button_background"
            android:text="MOVE TO PROCESSING"
            android:textColor="@android:color/white"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>