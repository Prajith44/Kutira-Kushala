<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="32dp"
    android:paddingEnd="16dp">

    <View
        android:id="@+id/view_line_top"
        android:layout_width="2dp"
        android:layout_height="24dp"
        android:background="#D1D5DB"
        app:layout_constraintEnd_toEndOf="@+id/iv_status_dot"
        app:layout_constraintStart_toStartOf="@+id/iv_status_dot"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/iv_status_dot"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="-12dp"
        android:background="@drawable/circle_white_bg"
        android:elevation="2dp"
        android:padding="4dp"
        android:src="@android:drawable/checkbox_off_background"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/view_line_top"
        app:tint="#D1D5DB" />

    <View
        android:id="@+id/view_line_bottom"
        android:layout_width="2dp"
        android:layout_height="40dp"
        android:background="#D1D5DB"
        app:layout_constraintEnd_toEndOf="@+id/iv_status_dot"
        app:layout_constraintStart_toStartOf="@+id/iv_status_dot"
        app:layout_constraintTop_toBottomOf="@+id/iv_status_dot" />

    <TextView
        android:id="@+id/tv_status_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:text="Requested"
        android:textColor="#9CA3AF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/iv_status_dot"
        app:layout_constraintStart_toEndOf="@+id/iv_status_dot"
        app:layout_constraintTop_toTopOf="@+id/iv_status_dot" />

    <TextView
        android:id="@+id/tv_status_desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Order placed by buyer"
        android:textColor="#9CA3AF"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/tv_status_title"
        app:layout_constraintTop_toBottomOf="@+id/tv_status_title" />

    <TextView
        android:id="@+id/tv_status_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="12:30 PM"
        android:textColor="#9CA3AF"
        android:textSize="10sp"
        app:layout_constraintStart_toStartOf="@+id/tv_status_title"
        app:layout_constraintTop_toBottomOf="@+id/tv_status_desc" />

</androidx.constraintlayout.widget.ConstraintLayout>